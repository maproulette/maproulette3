{
  "name": "maproulette",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "test -f .env || cp .env.example .env",
    "dev": "vite",
    "start": "vite",
    "build": "vite build && tsc",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "biome lint",
    "lint:fix": "biome lint --unsafe --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "check:force": "biome check --write --unsafe",
    "fix": "npm run check:fix && npm run type-check",
    "fix:force": "npm run check:force && npm run type-check",
    "generate:api-types": "openapi-typescript http://localhost:9000/assets/swagger.json -o src/types/openApiTypes.ts && npm run fix:force ",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen http://localhost:3005",
    "test:e2e:start": "NODE_ENV=test vite build --mode test && vite preview --port 3005",
    "test:db:start": "docker-compose -f docker-compose.test.yml up -d",
    "test:db:stop": "docker-compose -f docker-compose.test.yml down",
    "test:db:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "test:db:clean": "docker-compose -f docker-compose.test.yml down -v"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mapgrab/map-interface": "^1.0.2",
    "@mapgrab/playwright": "^0.0.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-router": "^1.132.7",
    "@tanstack/react-router-devtools": "^1.132.7",
    "@tanstack/router-plugin": "^1.132.7",
    "@types/maplibre-gl": "^1.13.2",
    "@types/supercluster": "^7.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "ky": "^1.11.0",
    "lucide-react": "^0.544.0",
    "map-gl-style-switcher": "^0.9.1",
    "maplibre-gl": "^5.16.0",
    "motion": "^12.23.22",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.64.0",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "react-use-websocket": "^4.13.0",
    "sonner": "^2.0.7",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.3.1",
    "terra-draw": "^1.23.1",
    "terra-draw-maplibre-gl-adapter": "^1.2.3",
    "zod": "^4.1.12"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --write --unsafe"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "baseline-browser-mapping": "^2.9.0",
    "dotenv": "^16.4.7",
    "lint-staged": "^15.5.2",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-svgr": "^4.5.0"
  }
}
