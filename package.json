{
  "name": "maproulette",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "test -f .env || cp .env.example .env",
    "dev": "vite",
    "start": "vite",
    "build": "vite build && tsc",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "biome lint",
    "lint:fix": "biome lint --unsafe --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "check:force": "biome check --write --unsafe",
    "fix": "npm run check:fix && npm run type-check",
    "fix:force": "npm run check:unsafe:fix && npm run type-check",
    "generate:api-types": "openapi-typescript http://localhost:9000/assets/swagger.json -o src/types/api/typesFromApi.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-router": "^1.132.7",
    "@tanstack/react-router-devtools": "^1.132.7",
    "@tanstack/router-plugin": "^1.132.7",
    "@types/maplibre-gl": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ky": "^1.11.0",
    "lucide-react": "^0.544.0",
    "maplibre-gl": "^5.9.0",
    "motion": "^12.23.22",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.64.0",
    "react-use-websocket": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-svgr": "^4.5.0",
    "web-vitals": "^5.1.0"
  }
}
