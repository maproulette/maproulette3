# Test Environment Configuration Template
# Copy this file to .env.test and fill in your actual values
# NEVER commit .env.test to the repository

# API Configuration
VITE_SERVER_OAUTH_URL="http://127.0.0.1:9001/auth/authenticate"
VITE_DISABLE_DEVTOOLS=true
VITE_API_BASE_URL="http://127.0.0.1:9001"

# Playwright Test Credentials
# These should be set as GitHub Secrets for CI/CD:
# - REACT_APP_USERNAME
# - REACT_APP_PASSWORD
REACT_APP_USERNAME='your-test-email@example.com'
REACT_APP_PASSWORD='your-test-password'

# GitHub API Token for Issue Tracking
# Generate at: https://github.com/settings/tokens
# Required scopes: repo
# Set as GitHub Secret: VITE_GITHUB_ISSUES_API_TOKEN
VITE_GITHUB_ISSUES_API_TOKEN='github_pat_YOUR_TOKEN_HERE'
VITE_GITHUB_ISSUES_API_OWNER='your-github-username'
VITE_GITHUB_ISSUES_API_REPO='your-repo-name'

# MapRoulette OAuth Credentials
# Obtain from MapRoulette OAuth application settings
# Set as GitHub Secrets:
# - MR_OAUTH_CONSUMER_KEY
# - MR_OAUTH_CONSUMER_SECRET
MR_OAUTH_CONSUMER_KEY="your-consumer-key"
MR_OAUTH_CONSUMER_SECRET="your-consumer-secret"
